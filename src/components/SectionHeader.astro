---
interface Props {
  label: string;
  title: string;
  description?: string;
}
const { label, title, description } = Astro.props;
---

<header class="mb-10 max-w-2xl">
  <div class="flex items-center gap-3 mb-4">
    <span class="block h-2 w-2 rounded-full bg-secondary-container pulse-secure"></span>
    <span class="mono-label text-secondary-container">{label}</span>
  </div>
  <h2 class="text-h2 text-on-surface">{title}</h2>
  {description && <p class="mt-3 text-body-lg text-on-surface-variant">{description}</p>}
</header>
