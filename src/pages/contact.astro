---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact — Moe Htet Kyaw">
  <div
    class="fixed inset-0 -z-10 opacity-[0.04] pointer-events-none"
    style="background-image: linear-gradient(rgba(0, 209, 255, 0.4) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 209, 255, 0.4) 1px, transparent 1px); background-size: 56px 56px;"
  >
  </div>

  <section class="px-8 pt-32 pb-20">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <h1
        class="font-display font-bold text-4xl md:text-5xl text-on-surface leading-[1.1]"
      >
        Let's Talks
      </h1>
      <p class="mt-6 text-on-surface-variant text-lg max-w-xl mx-auto">
        Send me a message/payload to get in touch with me :)
      </p>
    </div>

    <!-- SECURE_COMM_CHANNEL form -->
    <form
      id="contact-form"
      class="mx-auto max-w-3xl mt-12 glass glass-interactive rounded-md p-8 md:p-10"
      data-reveal
      data-delay="1"
    >
      <!-- Web3Forms hidden fields -->
      <!-- ⚠️  Replace YOUR_ACCESS_KEY_HERE with the key from web3forms.com -->
      <input
        type="hidden"
        name="access_key"
        value="03e27409-c979-467d-9fcb-f4932782f52b"
      />
      <input
        type="hidden"
        name="subject"
        value="New message from Portfolio — Moe Htet Kyaw"
      />
      <input type="hidden" name="from_name" value="Portfolio Contact Form" />
      <input type="hidden" name="redirect" value="false" />
      <input type="checkbox" name="botcheck" style="display:none;" />

      <div
        class="flex items-center gap-2 pb-4 mb-6 border-b border-outline-variant/40 text-primary-container"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect width="18" height="14" x="3" y="5" rx="2"></rect>
          <circle cx="9" cy="11" r="2"></circle>
          <path d="m21 19-3.5-3.5L15 18l-3-3-7 7"></path>
        </svg>
        <span class="mono-label">SECURE_COMM_CHANNEL</span>
      </div>

      <div class="space-y-6">
        <!-- OPERATOR_ID -->
        <div>
          <label for="operator-id" class="mono-label text-on-surface block mb-2"
            >OPERATOR_ID (NAME)</label
          >
          <div class="relative">
            <span
              class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"
                ></path><circle cx="12" cy="7" r="4"></circle>
              </svg>
            </span>
            <input
              id="operator-id"
              name="name"
              type="text"
              required
              placeholder="Enter your designation"
              class="w-full pl-11 pr-4 py-3 rounded bg-background border border-outline-variant text-on-surface placeholder:text-on-surface-variant/60 focus:outline-none focus:border-primary-container focus:glow-primary transition-all"
            />
          </div>
        </div>

        <!-- COMMS_RELAY -->
        <div>
          <label for="comms-relay" class="mono-label text-on-surface block mb-2"
            >COMMS_RELAY (EMAIL)</label
          >
          <div class="relative">
            <span
              class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                  d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
            </span>
            <input
              id="comms-relay"
              name="email"
              type="email"
              required
              placeholder="Enter routing address"
              class="w-full pl-11 pr-4 py-3 rounded bg-background border border-outline-variant text-on-surface placeholder:text-on-surface-variant/60 focus:outline-none focus:border-primary-container focus:glow-primary transition-all"
            />
          </div>
        </div>

        <!-- PAYLOAD -->
        <div>
          <label for="payload" class="mono-label text-on-surface block mb-2"
            >PAYLOAD (MESSAGE)</label
          >
          <div class="relative">
            <span
              class="absolute left-4 top-3.5 text-on-surface-variant pointer-events-none"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="16 18 22 12 16 6"></polyline><polyline
                  points="8 6 2 12 8 18"></polyline>
              </svg>
            </span>
            <textarea
              id="payload"
              name="message"
              rows="6"
              required
              placeholder="Encrypt your payload here..."
              class="w-full pl-11 pr-4 py-3 rounded bg-background border border-outline-variant text-on-surface placeholder:text-on-surface-variant/60 focus:outline-none focus:border-primary-container focus:glow-primary transition-all resize-none"
            ></textarea>
          </div>
        </div>

        <!-- TRANSMIT button -->
        <button
          id="submit-btn"
          type="submit"
          class="w-full inline-flex items-center justify-center gap-2 px-6 py-4 rounded bg-primary-container text-on-primary font-medium tracking-wide hover:glow-primary-strong hover:brightness-110 transition-all disabled:opacity-60 disabled:pointer-events-none"
        >
          <!-- idle -->
          <span id="btn-idle" class="inline-flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"
              ></path>
            </svg>
            TRANSMIT PAYLOAD
          </span>
          <!-- sending -->
          <span id="btn-sending" class="hidden items-center gap-2">
            <svg
              class="animate-spin"
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
            </svg>
            TRANSMITTING...
          </span>
        </button>

        <!-- Status message -->
        <div
          id="form-status"
          class="hidden text-center mono-label text-sm py-3 px-4 rounded"
          role="alert"
        >
        </div>
      </div>
    </form>

    <!-- Social tiles -->
    <div
      class="mt-12 flex items-center justify-center gap-6"
      data-reveal
      data-delay="2"
    >
      <a
        href="https://www.linkedin.com/in/moekyaw"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col items-center gap-2"
      >
        <span
          class="h-14 w-14 rounded glass flex items-center justify-center text-on-surface-variant group-hover:text-primary-container group-hover:glow-primary transition-all"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path><rect width="4" height="12" x="2" y="9"></rect><circle
              cx="4"
              cy="4"
              r="2"></circle>
          </svg>
        </span>
        <span
          class="mono-label text-[11px] text-on-surface-variant group-hover:text-primary-container transition-colors"
          >LINKEDIN</span
        >
      </a>
      <a
        href="https://github.com/MHK456"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col items-center gap-2"
      >
        <span
          class="h-14 w-14 rounded glass flex items-center justify-center text-on-surface-variant group-hover:text-primary-container group-hover:glow-primary transition-all"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path><path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
        </span>
        <span
          class="mono-label text-[11px] text-on-surface-variant group-hover:text-primary-container transition-colors"
          >GITHUB</span
        >
      </a>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const btnIdle = document.getElementById("btn-idle") as HTMLElement;
  const btnSend = document.getElementById("btn-sending") as HTMLElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const status = document.getElementById("form-status") as HTMLElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Show sending state
    btnIdle.classList.add("hidden");
    btnSend.classList.remove("hidden");
    btnSend.classList.add("inline-flex");
    submitBtn.disabled = true;
    status.classList.add("hidden");

    try {
      const data = new FormData(form);
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: data,
      });
      const json = await res.json();

      if (json.success) {
        status.textContent = "✓  TRANSMISSION SUCCESSFUL — message received.";
        status.className =
          "text-center mono-label text-sm py-3 px-4 rounded bg-secondary-container/10 border border-secondary-container/40 text-secondary-container";
        form.reset();
      } else {
        throw new Error(json.message || "Submission failed");
      }
    } catch (err) {
      status.textContent =
        "✗  TRANSMISSION FAILED — please try again or email directly.";
      status.className =
        "text-center mono-label text-sm py-3 px-4 rounded bg-error-container/20 border border-error/30 text-error";
    } finally {
      btnSend.classList.add("hidden");
      btnSend.classList.remove("inline-flex");
      btnIdle.classList.remove("hidden");
      submitBtn.disabled = false;
      status.classList.remove("hidden");
    }
  });
</script>
